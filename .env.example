# App runtime
APP_PORT=4100
POSTGRES_PORT=55432
PHX_HOST=localhost

# Database
POSTGRES_DB=social_scribe_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_POOL_SIZE=10

# OAuth and API keys
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4100/auth/google/callback

RECALL_API_KEY=
RECALL_REGION=
GEMINI_API_KEY=

HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:4100/auth/hubspot/callback

SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:4100/auth/salesforce/callback
SALESFORCE_SITE=https://login.salesforce.com

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4100/auth/linkedin/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4100/auth/facebook/callback
FACEBOOK_OAUTH_SCOPE=public_profile

# Security/performance guardrails (Step 9 baseline)
TRANSCRIPT_MAX_CHARS=2000000
AI_PROMPT_MAX_CHARS=2200000
CRM_SEARCH_MAX_CHARS=120
CRM_UPDATE_MAX_FIELDS=25
CRM_FIELD_VALUE_MAX_CHARS=2000
SOCIAL_POST_MAX_CHARS=3000
OAUTH_STATE_MAX_CHARS=200

# Rate limit defaults
RL_AUTH_START_WINDOW_MS=60000
RL_AUTH_START_MAX_REQUESTS=20
RL_AUTH_CALLBACK_WINDOW_MS=60000
RL_AUTH_CALLBACK_MAX_REQUESTS=30
RL_CRM_SEARCH_WINDOW_MS=60000
RL_CRM_SEARCH_MAX_REQUESTS=40
RL_CRM_UPDATE_WINDOW_MS=60000
RL_CRM_UPDATE_MAX_REQUESTS=20
RL_AI_SUGGESTIONS_WINDOW_MS=60000
RL_AI_SUGGESTIONS_MAX_REQUESTS=12

# Outbound HTTP timeout/retry defaults
HTTP_CONNECT_TIMEOUT_MS=5000
HTTP_RECV_TIMEOUT_MS=20000
HTTP_GEMINI_RECV_TIMEOUT_MS=180000
HTTP_RETRY_ATTEMPTS=2
HTTP_RETRY_BACKOFF_BASE_MS=250
HTTP_RETRY_BACKOFF_MAX_MS=2000

